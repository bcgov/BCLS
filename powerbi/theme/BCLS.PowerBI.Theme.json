{
  "name": "BCLS Dashboard Theme",
  "dataColors": [
    "#003366",
    "#1A5276",
    "#2E86AB",
    "#FCBA19",
    "#276749",
    "#C05621",
    "#C53030",
    "#8E44AD",
    "#718096",
    "#ADB5BD"
  ],
  "background": "#F2F5F9",
  "foreground": "#1A202C",
  "tableAccent": "#003366",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D6DCE4"
              }
            },
            "radius": 6
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1A202C"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 10
          }
        ]
      }
    },
    "card": {
      "*": {
        "categoryLabels": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 10
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#003366"
              }
            },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "outlineColor": {
              "solid": {
                "color": "#D6DCE4"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "backColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontColor": {
              "solid": {
                "color": "#003366"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#1A202C"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#1A202C"
              }
            },
            "textSize": 10
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "textSize": 9
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Bottom",
            "fontSize": 9,
            "fontColor": {
              "solid": {
                "color": "#4A5568"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 9
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "clusteredColumnChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Bottom",
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 9
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4A5568"
              }
            },
            "fontSize": 9
          }
        ]
      }
    }
  }
}

